# Required for live Austin pipeline (Mapbox Tilequery confirms intersections).
# Copy the same `pk.*` token you use in the frontend, or set a dedicated server token.
MAPBOX_ACCESS_TOKEN=pk.your_mapbox_public_token_here

# Optional aliases (dev convenience)
# MAPBOX_TOKEN=pk....
# VITE_MAPBOX_TOKEN=pk....

# Optional: west,south,east,north (WGS84). Defaults to central Austin.
# AUSTIN_BBOX=-97.78,30.24,-97.68,30.32

# Optional tuning
# MAX_CRASH_ROWS=120000
# MAX_WAYS_TOPO=6500
# MAX_WAYS_RENDER=2500
# MAX_IX_CANDIDATES=900
# MAX_INTERSECTIONS=250
# CACHE_MAX_AGE_HOURS=6

# Optional: force offline CSV mode (skips live fetches entirely)
# SEGMENTS_CSV_PATH=data/segments_features.csv
